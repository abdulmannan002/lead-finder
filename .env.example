# --- Core ---
NODE_ENV=development
PORT=3001

# --- Database (docker-compose defaults) ---
DATABASE_URL=postgresql://signx:signx@localhost:5432/signx_reach?schema=public

# --- Redis / BullMQ ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Secrets vault (AES-256-GCM app-layer encryption, used from M1) ---
# 32 bytes, base64. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MASTER_ENCRYPTION_KEY=change-me-32-bytes-base64

# --- Platform mail (invites; mailhog locally) ---
SMTP_HOST=localhost
SMTP_PORT=1025
MAIL_FROM=SignX Reach <no-reply@signxreach.local>

# --- URLs ---
WEB_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# --- Observability & ops (all optional; features stay off when unset) ---
# SENTRY_DSN=
# ADMIN_DASH_USER=            # enables bull-board on the worker
# ADMIN_DASH_PASS=
# BULL_BOARD_PORT=3002
# BACKUP_DIR=/var/backups/signx-reach
# BACKUP_RETENTION_DAYS=14
