# Production env for docker-compose.prod.yml — copy to .env.production
# on the VM and fill every "change-me". NEVER commit .env.production.

NODE_ENV=production

# --- Domain / TLS (Caddy) ---
DOMAIN=market.example.pk
ACME_EMAIL=you@example.pk

# --- Database (compose wires DATABASE_URL from these) ---
POSTGRES_USER=signx
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=signx_reach

# --- Auth ---
# Generate each: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Secrets vault (AES-256-GCM) ---
# 32 bytes base64: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Losing this key orphans every stored integration/SMTP credential — back it up separately.
MASTER_ENCRYPTION_KEY=change-me-32-bytes-base64

# --- Platform mail (workspace invites + email verification) ---
# Free tier: Brevo (300/day) or Resend (100/day) SMTP creds.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
MAIL_FROM=SignX Market <no-reply@market.example.pk>

# --- URLs (same-domain: Caddy routes /api/* to the API) ---
WEB_APP_URL=https://market.example.pk

# --- Marketplace AI (platform-paid haiku key with a small spend cap) ---
# PLATFORM_ANTHROPIC_KEY=

# --- Observability & ops (optional) ---
# SENTRY_DSN=
# ADMIN_DASH_USER=
# ADMIN_DASH_PASS=
# BULL_BOARD_PORT=3002
BACKUP_DIR=/var/backups/signx-reach
BACKUP_RETENTION_DAYS=14
# rclone remote for offsite backups (Cloudflare R2 free 10GB), e.g. r2:signx-backups
# BACKUP_RCLONE_REMOTE=
